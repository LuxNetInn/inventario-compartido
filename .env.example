# ═══════════════════════════════════════════════════════════════
# InventarioApp — Variables de entorno
# ═══════════════════════════════════════════════════════════════

# ─── Backend (Render) ───────────────────────────────────────────
# Secret para firmar JWT de sesiones (mínimo 32 caracteres)
JWT_SECRET=cambiar-esto-por-un-secret-seguro-de-32-chars-min

# URL de la base de datos MySQL (Render te la da al crear la DB)
DATABASE_URL=mysql://user:password@host:3306/dbname

# Origenes permitidos para CORS (URL de Cloudflare Pages)
CORS_ORIGINS=https://inventario-app.pages.dev

# App ID (cualquier string único)
VITE_APP_ID=inventario-compartido

# ─── Frontend (Cloudflare Pages) ───────────────────────────────
# URL completa del backend en Render + /api/trpc
VITE_API_URL=https://inventario-backend.onrender.com/api/trpc
